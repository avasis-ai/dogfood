# Copy to .env.local in apps/web and .env in apps/api; never commit real values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# LLM provider keys (users plug these in at runtime via the UI,
# but local dev / server-side eval can use these)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# OpenClaw first-class connector (points at a running OpenClaw gateway)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=

# Auth (Clerk optional — Supabase Auth is the default)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
